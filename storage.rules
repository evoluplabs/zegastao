rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Statements live under uploads/{userId}/{uploadId}. Only the owner may
    // write; the onUpload Cloud Function deletes the file after processing.
    match /uploads/{userId}/{uploadId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
