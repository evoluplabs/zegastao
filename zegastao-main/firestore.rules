rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin check via custom claim (admin: true).
    // Para setar: rodar scripts/set-admin.ts <email> e re-logar no app.
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Modo casal/família: verifica se o parceiro autenticado tem acesso compartilhado.
    // Usa get() no profile para checar sharedWithUid — 1 leitura extra por regra avaliada.
    function isPartnerOf(userId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(userId)/profile/main) &&
        get(/databases/$(database)/documents/users/$(userId)/profile/main).data.sharedWithUid == request.auth.uid;
    }

    // Single-user + parceiro: leitura para o dono, admin ou parceiro vinculado.
    // Escrita apenas para o dono ou admin (parceiro não pode alterar dados do outro).
    match /users/{userId}/{document=**} {
      allow read: if request.auth != null &&
        (request.auth.uid == userId || isAdmin() || isPartnerOf(userId));
      allow write: if request.auth != null &&
        (request.auth.uid == userId || isAdmin()) &&
        document != 'subscription/main';
    }

    match /b2b_leads/{leadId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }
    match /blog_posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /betting_analyses/{docId} {
      allow read, write: if request.auth != null &&
        (request.auth.uid == resource.data.userId || isAdmin());
    }

    // Cache coletivo de dados de API (sem PII) — leitura para autenticados,
    // escrita só via Cloud Functions (Admin SDK ignora estas regras).
    match /betting_cache/{cacheKey} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Modelo coletivo de aprendizado (anônimo) — mesma política do cache.
    match /betting_learning_global/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Mercado P2P da Guilda — leitura pública, escrita por autenticados, remoção só pelo dono.
    match /marketplace/{listingId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.userId;
    }

    // Stats sociais públicos — SOMENTE dados de jogo (alias, nível, XP, streak, conquistas).
    // NUNCA expõe valores financeiros (R$, dívidas, saldo).
    match /social_stats/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Ranking global — gerado 1×/dia pela Cloud Function buildLeaderboard (Admin SDK).
    // Leitura para autenticados; escrita apenas via Admin SDK (função).
    match /leaderboard/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Mural da Vila — leitura pública, criação por autenticados, edição/remoção pelo autor.
    match /vila_posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.userId;
    }
  }
}
