# Frontend Firebase config — copy to .env.local and fill in. NEVER commit .env.local.
# Get these from Firebase Console → Project Settings → Your apps → SDK setup.
# NOTE: the Anthropic API key is NOT here. It lives only in functions/.env.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Push Notifications (Firebase Cloud Messaging VAPID key)
# Get from: Firebase Console → Project Settings → Cloud Messaging → Web Push certificates → Key pair
VITE_FIREBASE_VAPID_KEY=

# Mixpanel (opcional — analytics de funil)
# Get from: mixpanel.com → Project Settings → Project Token
VITE_MIXPANEL_TOKEN=

# Sentry (opcional — error tracking, plano free em sentry.io)
# Get from: sentry.io → Settings → Projects → DSN
VITE_SENTRY_DSN=
