rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Extratos: processados e deletados pela Cloud Function após a importação.
    match /uploads/{userId}/{uploadId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size <= 50 * 1024 * 1024
        && request.resource.contentType.matches('application/(pdf|csv|vnd.ms-excel|vnd.openxmlformats.*)|text/(csv|plain)');
    }

    // Contratos: analisados pela IA. O arquivo NUNCA é deletado — o usuário tem direito a ele.
    match /contracts/{userId}/{contractId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size <= 100 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf|image/(jpeg|png|webp)');
    }

    // Biblioteca geral de documentos do usuário.
    match /documents/{userId}/{docId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size <= 50 * 1024 * 1024;
    }
  }
}
